  "query": "\n                SELECT mf.id, rf.retained_path, mf.file_path\n                FROM media_files mf\n                JOIN retention_files rf ON rf.media_file_id = mf.id\n                WHERE mf.workflow_state = 'done'\n                  AND COALESCE(jsonb_exists(mf.transcode_spec, 'vmaf'), false) = false\n            ",
